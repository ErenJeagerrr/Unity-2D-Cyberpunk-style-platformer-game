  Pieces:
  - CharacterName: Jack
    CharacterContent: "Aria\u2026 there\u2019s something you need to know."
  - CharacterName: Aria
    CharacterContent: "My sister\u2019s last signal came from Apex territory."
  - CharacterName: Jack
    CharacterContent: "It wasn\u2019t a disappearance.\nIt was a cleanup."
  - CharacterName: Aria
    CharacterContent: "\u2026Say that again."
  - CharacterName: Jack
